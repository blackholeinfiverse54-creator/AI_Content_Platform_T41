    },
    {
      "capability_id": "ARTHA-FINREPORT-001",
      "name": "Financial Reporting Engine",
      "contract_file": "capability_contracts/financial_reporting_capability_contract.json",
      "version": "1.0.0",
      "status": "STABLE",
      "category": "CORE_ACCOUNTING"
    },
    {
      "capability_id": "ARTHA-SIGNAL-001",
      "name": "Compliance Signal Engine",
      "contract_file": "capability_contracts/signal_capability_contract.json",
      "version": "1.0.0",
      "status": "STABLE",
      "category": "COMPLIANCE"
    },
    {
      "capability_id": "ARTHA-MULTICOMPANY-001",
      "name": "Multi-Company Engine",
