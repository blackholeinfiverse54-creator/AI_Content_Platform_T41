{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "registry_id": "ARTHA-CAPABILITY-REGISTRY",
  "version": "1.0.0",
  "status": "ACTIVE",
  "owner": "Ashmit",
  "last_verified": "2025-02-19",
  "ecosystem": "BHIV",
  "platform": "ARTHA",
  "description": "Central capability registry for all reusable ARTHA modules exposed to the BHIV ecosystem. Each capability is independently discoverable, versioned, and bounded by explicit authority limits.",

  "capabilities": [
    {
      "capability_id": "ARTHA-LEDGER-001",
      "name": "Ledger Engine",
