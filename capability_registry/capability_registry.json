      "version": "1.0.0",
      "status": "STABLE",
      "category": "CORE_ACCOUNTING"
    },
    {
      "capability_id": "ARTHA-AUDIT-001",
      "name": "Audit Engine",
      "contract_file": "capability_contracts/audit_capability_contract.json",
      "version": "1.0.0",
      "status": "STABLE",
      "category": "GOVERNANCE"
    },
    {
      "capability_id": "ARTHA-TRACE-001",
      "name": "Trace Engine",
      "contract_file": "capability_contracts/trace_capability_contract.json",
      "version": "1.0.0",
      "status": "STABLE",
      "category": "GOVERNANCE"
    },
    {
      "capability_id": "ARTHA-EVIDENCE-001",
      "name": "Evidence Engine",
      "contract_file": "capability_contracts/evidence_capability_contract.json",
      "version": "1.0.0",
      "status": "STABLE",
